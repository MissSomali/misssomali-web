# Database Connection
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Neon Authentication
NEXT_PUBLIC_NEON_AUTH_URL="http://localhost:3000"
NEON_AUTH_URL="http://localhost:3000"
NEON_AUTH_COOKIE_SECRET="a-random-secret-key-of-at-least-32-characters"

# Cloudinary Config (for image uploads)
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Resend Email Config (for email notifications)
RESEND_API_KEY="re_your-resend-api-key"

# Optional: Demo Login Credentials
NEXT_PUBLIC_DEMO_USER_MAIL=""
NEXT_PUBLIC_DEMO_USER_PASS=""
